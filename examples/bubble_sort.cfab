var arr = Array(5);
arr[0] = 5;
arr[1] = 3;
arr[2] = 8;
arr[3] = 1;
arr[4] = 4;

for (var i = 0; i < 4; i = i + 1) {
    for (var j = 0; j < 4 - i; j = j + 1) {
        if (arr[j] > arr[j + 1]) {
            var tmp = arr[j];
            arr[j] = arr[j + 1];
            arr[j + 1] = tmp;
        }
    }
}

for (var k = 0; k < 5; k = k + 1) {
    print arr[k];
}
